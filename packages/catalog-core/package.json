{
  "name": "@ocp-catalog/catalog-core",
  "version": "0.1.0",
  "description": "Core services, contracts, validators, and projections for an OCP Catalog Node.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "keywords": [
    "ocp",
    "catalog",
    "commercial-object",
    "protocol",
    "elysia",
    "bun"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@ocp-catalog/config": "workspace:*",
    "@ocp-catalog/db": "workspace:*",
    "@ocp-catalog/ocp-schema": "workspace:*",
    "@ocp-catalog/shared": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "zod": "^4.1.12"
  }
}
