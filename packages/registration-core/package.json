{
  "name": "@ocp-catalog/registration-core",
  "version": "0.1.0",
  "description": "Core services for OCP Catalog Registration / Catalog Registry.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@ocp-catalog/registration-schema": "workspace:*",
    "@ocp-catalog/config": "workspace:*",
    "@ocp-catalog/db": "workspace:*",
    "@ocp-catalog/ocp-schema": "workspace:*",
    "@ocp-catalog/shared": "workspace:*",
    "drizzle-orm": "^0.44.7"
  }
}
