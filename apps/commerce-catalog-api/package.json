{
  "name": "@ocp-catalog/commerce-catalog-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd ../.. && bun --watch apps/commerce-catalog-api/src/index.ts",
    "start": "cd ../.. && bun apps/commerce-catalog-api/src/index.ts",
    "worker:dev": "cd ../.. && bun --watch apps/commerce-catalog-api/src/worker.ts",
    "worker": "cd ../.. && bun apps/commerce-catalog-api/src/worker.ts",
    "embedding:batch": "cd ../.. && bun apps/commerce-catalog-api/src/scripts/embedding-batch-backfill.ts",
    "search:text-backfill": "cd ../.. && bun apps/commerce-catalog-api/src/scripts/opensearch-text-backfill.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "bun build src/index.ts src/worker.ts --outdir dist --target bun",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests --path-ignore-patterns='**/*-integration.test.ts'",
    "test:integration": "bun test --timeout=10000 src/*-integration.test.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@ocp-catalog/auth-core": "workspace:*",
    "@ocp-catalog/activity-db": "workspace:*",
    "@ocp-catalog/catalog-core": "workspace:*",
    "@ocp-catalog/catalog-db": "workspace:*",
    "@ocp-catalog/config": "workspace:*",
    "@ocp-catalog/db": "workspace:*",
    "@ocp-catalog/ocp-activity-core": "workspace:*",
    "@ocp-catalog/ocp-activity-schema": "workspace:*",
    "@ocp-catalog/ocp-schema": "workspace:*",
    "@ocp-catalog/shared": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "elysia": "^1.3.22",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.7",
    "zod": "^4.1.12"
  }
}
