# ---- 自身 ----
SKILL_GATEWAY_PORT=4330
SKILL_GATEWAY_PUBLIC_BASE_URL=http://localhost:4330

# ---- 上游数据源 ----
# ocp_mcp        线上 ocp.deeplumen.io/mcp,走 MCP JSON-RPC(默认,真实数据)
# ocp_http       线上 OCP 注册中心 + catalog 节点,走纯 HTTP REST(真实数据,不经过 MCP)
# local_catalogs 本地 SKILL_GATEWAY_CATALOGS 列表(离线 / mock 联调)
SKILL_GATEWAY_UPSTREAM=ocp_mcp
SKILL_GATEWAY_OCP_MCP_URL=https://ocp.deeplumen.io/mcp
# 仅 ocp_http 模式生效;searchCatalogs 会在其后拼 /ocp/catalogs/search
SKILL_GATEWAY_OCP_REGISTRATION_URL=https://ocp.deeplumen.io/registry

# ---- API Key ----
# 逗号分隔的合法 key 列表 (M1: 静态;M2 切到 DB)
# 平台审核期可先用一个统一 key,上线后按学生分发
SKILL_GATEWAY_API_KEYS=sk_dev_demo_001

# ---- 下游 OCP Catalog Node 列表 ----
# JSON 数组,每项 { id, name, base_url }
# 默认指向 demo 端口;真实部署改成公网地址
SKILL_GATEWAY_CATALOGS=[{"id":"cat_alimama","name":"Alimama","base_url":"http://localhost:4310"},{"id":"cat_jdunion","name":"JD Union","base_url":"http://localhost:4320"},{"id":"cat_pdd","name":"PDD","base_url":"http://localhost:4340"}]

# ---- 调用超时 ----
SKILL_GATEWAY_FANOUT_TIMEOUT_MS=8000

# ---- telemetry ----
# in-memory (默认) | jsonl
SKILL_GATEWAY_TELEMETRY_SINK=in-memory
SKILL_GATEWAY_TELEMETRY_JSONL_PATH=./var/telemetry.jsonl
