{
  "name": "@ocp-catalog/ocp-user-demo-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd ../.. && bun --watch apps/ocp-user-demo-api/src/index.ts",
    "start": "cd ../.. && bun apps/ocp-user-demo-api/src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "@ocp-catalog/config": "workspace:*",
    "@ocp-catalog/shared": "workspace:*",
    "elysia": "^1.3.22",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
