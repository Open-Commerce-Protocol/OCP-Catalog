{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocp.dev/schema/ocp.catalog.handshake.v1/provider-registration.schema.json",
  "type": "object",
  "required": [
    "ocp_version",
    "kind",
    "id",
    "catalog_id",
    "provider",
    "registration_version",
    "updated_at",
    "object_declarations"
  ],
  "properties": {
    "ocp_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "ProviderRegistration"
    },
    "id": {
      "type": "string"
    },
    "catalog_id": {
      "type": "string"
    },
    "registration_version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "$ref": "https://ocp.dev/schema/ocp.catalog.handshake.v1/common.schema.json#/$defs/Timestamp"
    },
    "provider": {
      "type": "object",
      "required": ["provider_id", "entity_type", "display_name", "homepage"],
      "properties": {
        "provider_id": {
          "type": "string"
        },
        "entity_type": {
          "type": "string",
          "enum": ["merchant", "organization", "individual", "platform", "other"]
        },
        "display_name": {
          "type": "string"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "contact_email": {
          "type": "string",
          "format": "email"
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "object_declarations": {
      "type": "array",
      "minItems": 1,
      "items": {
      "type": "object",
        "required": ["guaranteed_fields", "sync"],
        "properties": {
          "guaranteed_fields": {
            "type": "array",
            "items": {
              "$ref": "https://ocp.dev/schema/ocp.catalog.handshake.v1/common.schema.json#/$defs/FieldRef"
            },
            "uniqueItems": true
          },
          "optional_fields": {
            "type": "array",
            "items": {
              "$ref": "https://ocp.dev/schema/ocp.catalog.handshake.v1/common.schema.json#/$defs/FieldRef"
            },
            "uniqueItems": true
          },
          "sync": {
            "type": "object",
            "required": ["preferred_capabilities"],
            "properties": {
              "preferred_capabilities": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "avoid_capabilities_unless_necessary": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              },
              "provider_endpoints": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "https://ocp.dev/schema/ocp.catalog.handshake.v1/common.schema.json#/$defs/ProviderEndpoint"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
