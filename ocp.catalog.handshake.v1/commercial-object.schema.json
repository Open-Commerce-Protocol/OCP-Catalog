{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocp.dev/schema/ocp.catalog.handshake.v1/commercial-object.schema.json",
  "type": "object",
  "required": ["ocp_version", "kind", "id", "object_id", "object_type", "provider_id", "title", "descriptors"],
  "properties": {
    "ocp_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "CommercialObject"
    },
    "id": {
      "type": "string"
    },
    "object_id": {
      "type": "string"
    },
    "object_type": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "draft"],
      "default": "active"
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "descriptors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["pack_id", "data"],
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "schema_uri": {
            "type": "string",
            "format": "uri"
          },
          "data": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
