{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocp.dev/schema/ocp.catalog.center.v1/catalog-registration-result.schema.json",
  "type": "object",
  "required": [
    "ocp_version",
    "kind",
    "id",
    "center_id",
    "status",
    "manifest_fetch_status",
    "verification_status",
    "health_status",
    "indexed",
    "warnings",
    "verification_challenges"
  ],
  "properties": {
    "ocp_version": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "CatalogRegistrationResult" },
    "id": { "type": "string", "minLength": 1 },
    "center_id": { "type": "string", "minLength": 1 },
    "catalog_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "accepted_indexed",
        "accepted_pending_verification",
        "accepted_limited",
        "rejected",
        "stale_ignored"
      ]
    },
    "effective_registration_version": { "type": "integer", "minimum": 1 },
    "manifest_fetch_status": {
      "type": "string",
      "enum": ["not_attempted", "fetched", "failed"]
    },
    "verification_status": {
      "type": "string",
      "enum": ["verified", "challenge_required", "failed", "not_required"]
    },
    "health_status": {
      "type": "string",
      "enum": ["healthy", "unhealthy", "unknown"]
    },
    "indexed": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification_challenges": {
      "type": "array",
      "items": {
        "$ref": "https://ocp.dev/schema/ocp.catalog.center.v1/catalog-verification-challenge.schema.json"
      }
    },
    "catalog_access_token": { "type": "string" },
    "token_issued_at": { "type": "string", "format": "date-time" },
    "message": { "type": "string" }
  },
  "additionalProperties": false
}
