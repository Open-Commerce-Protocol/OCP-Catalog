{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocp.dev/schema/ocp.catalog.center.v1/center-discovery.schema.json",
  "type": "object",
  "required": [
    "ocp_version",
    "kind",
    "center_id",
    "center_name",
    "center_protocol",
    "center_protocol_version",
    "manifest_url",
    "catalog_registration_url",
    "catalog_search_url"
  ],
  "properties": {
    "ocp_version": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "CenterDiscovery" },
    "center_id": { "type": "string", "minLength": 1 },
    "center_name": { "type": "string", "minLength": 1 },
    "center_protocol": { "type": "string", "const": "ocp.catalog.center.v1" },
    "center_protocol_version": { "type": "string", "minLength": 1 },
    "manifest_url": { "type": "string", "format": "uri" },
    "catalog_registration_url": { "type": "string", "format": "uri" },
    "catalog_search_url": { "type": "string", "format": "uri" }
  },
  "additionalProperties": false
}
