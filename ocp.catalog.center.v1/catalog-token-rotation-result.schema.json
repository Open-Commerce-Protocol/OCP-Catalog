{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocp.dev/schema/ocp.catalog.center.v1/catalog-token-rotation-result.schema.json",
  "type": "object",
  "required": [
    "ocp_version",
    "kind",
    "id",
    "center_id",
    "catalog_id",
    "catalog_access_token",
    "token_issued_at"
  ],
  "properties": {
    "ocp_version": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "CatalogTokenRotationResult" },
    "id": { "type": "string", "minLength": 1 },
    "center_id": { "type": "string", "minLength": 1 },
    "catalog_id": { "type": "string", "minLength": 1 },
    "catalog_access_token": { "type": "string", "minLength": 1 },
    "token_issued_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
