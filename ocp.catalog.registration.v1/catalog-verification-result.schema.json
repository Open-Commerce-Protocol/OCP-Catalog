{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocp.dev/schema/ocp.catalog.registration.v1/catalog-verification-result.schema.json",
  "type": "object",
  "required": [
    "ocp_version",
    "kind",
    "id",
    "registration_id",
    "catalog_id",
    "verification_status",
    "indexed",
    "verified_domains",
    "failed_challenges"
  ],
  "properties": {
    "ocp_version": { "type": "string", "const": "1.0" },
    "kind": { "type": "string", "const": "CatalogVerificationResult" },
    "id": { "type": "string", "minLength": 1 },
    "registration_id": { "type": "string", "minLength": 1 },
    "catalog_id": { "type": "string", "minLength": 1 },
    "verification_status": {
      "type": "string",
      "enum": ["verified", "challenge_required", "failed"]
    },
    "indexed": { "type": "boolean" },
    "verified_domains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failed_challenges": {
      "type": "array",
      "items": { "type": "string" }
    },
    "catalog_access_token": { "type": "string" },
    "message": { "type": "string" }
  },
  "additionalProperties": false
}
