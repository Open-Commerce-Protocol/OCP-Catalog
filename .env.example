# OCP Catalog v2 environment
#
# Copy this file to .env for local development. Keep real secrets out of
# committed files.

# PostgreSQL connection used by Drizzle.
DATABASE_URL=postgres://ocp:ocp@localhost:5432/ocp_catalog

# Main Catalog HTTP API.
CATALOG_API_PORT=4000

# Public base URL used in well-known discovery and CatalogManifest endpoints.
CATALOG_PUBLIC_BASE_URL=http://localhost:4000

# Commerce Provider HTTP API and public base URL.
PROVIDER_API_PORT=4200
PROVIDER_PUBLIC_BASE_URL=http://localhost:4200

# Commerce Provider admin web.
PROVIDER_ADMIN_UI_PORT=4210
VITE_PROVIDER_API_BASE_URL=http://localhost:4200

# User demo web.
USER_DEMO_UI_PORT=4220
USER_DEMO_API_PORT=4230
VITE_USER_DEMO_AGENT_API_BASE_URL=http://localhost:4230
VITE_REGISTRATION_DISCOVERY_URL=https://ocp.deeplumen.io/.well-known/ocp-registration
VITE_DEFAULT_CATALOG_QUERY_URL=http://localhost:4000/ocp/query
VITE_DEFAULT_CATALOG_RESOLVE_URL=http://localhost:4000/ocp/resolve
OCP_SITE_PORT=5173

# OCP Catalog Registration node HTTP API.
REGISTRATION_API_PORT=4100

# Public base URL used in Registration node discovery and manifest endpoints.
REGISTRATION_PUBLIC_BASE_URL=https://ocp.deeplumen.io
REGISTRATION_DISCOVERY_URL=https://ocp.deeplumen.io/.well-known/ocp-registration

# Periodic refresh of verified/indexed Catalog manifests and health status.
REGISTRATION_REFRESH_SCHEDULER_ENABLED=true
REGISTRATION_REFRESH_INTERVAL_SECONDS=300
REGISTRATION_HEALTH_CHECK_TIMEOUT_MS=5000
REGISTRATION_HEALTH_FAILURE_STALE_THRESHOLD=3

# Catalog identity for local development.
CATALOG_ID=cat_local_dev
CATALOG_NAME=Commerce Product Search Catalog

# Commerce Provider identity for local development.
COMMERCE_PROVIDER_ID=commerce_provider_local_dev
COMMERCE_PROVIDER_NAME=Local Commerce Provider
COMMERCE_PROVIDER_CONTACT_EMAIL=ops@example.test
COMMERCE_PROVIDER_DOMAIN=localhost

# Registration node identity for local development.
REGISTRATION_ID=registration_local_dev
REGISTRATION_NAME=Local OCP Catalog Registration Node

# Development admin key accepted by x-api-key or Authorization: Bearer.
API_KEY_DEV=dev-api-key

# Optional comma-separated extra admin keys for local/shared environments.
API_KEYS=

# Semantic search embeddings are always enabled.
# If OPENAI_API_KEY is set, the catalog calls OPENAI_BASE_URL /embeddings.
# Without OPENAI_API_KEY, it falls back to deterministic local hash embeddings.
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
USER_DEMO_AGENT_MODEL=qwen3.6-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# OCP MCP gateway.
OCP_MCP_DEFAULT_REGISTRATION_URL=http://localhost:4100
OCP_MCP_REQUEST_TIMEOUT_MS=10000
OCP_MCP_USER_AGENT=ocp-mcp-server/0.1.0
OCP_MCP_API_KEY=
OCP_MCP_HTTP_PORT=4300
OCP_MCP_HTTP_PATH=/mcp

# Alimama affiliate Catalog Node.
ALIMAMA_CATALOG_PORT=4310
ALIMAMA_CATALOG_ID=cat_alimama_affiliate
ALIMAMA_CATALOG_NAME=Alimama Affiliate Catalog
ALIMAMA_CATALOG_PUBLIC_BASE_URL=http://localhost:4310
ALIMAMA_CATALOG_ADMIN_KEY=dev-alimama-admin-key
ALIMAMA_MOCK=true
ALIMAMA_APP_KEY=
ALIMAMA_APP_SECRET=
ALIMAMA_ADZONE_ID=mock_adzone_001
ALIMAMA_BASE_URL=https://gw.api.taobao.com/router/rest
ALIMAMA_QUERY_TIMEOUT_MS=5000
ALIMAMA_DEFAULT_PAGE_SIZE=20
ALIMAMA_ORDER_POLL_INTERVAL_SEC=0

# Shopify Catalog (OCP bridge).
# Realtime proxy over Shopify Catalog MCP. SHOPIFY_MOCK=true reads fixtures
# from tests/fixtures/ and does NOT hit Shopify, so it works without keys.
SHOPIFY_CATALOG_PORT=4320
SHOPIFY_CATALOG_ID=cat_shopify_global
SHOPIFY_CATALOG_NAME=Shopify Catalog (OCP bridge)
SHOPIFY_CATALOG_PUBLIC_BASE_URL=http://localhost:4320
SHOPIFY_CATALOG_ADMIN_KEY=dev-shopify-admin-key
SHOPIFY_MOCK=true
# global | storefront. storefront requires SHOPIFY_STORE_DOMAIN.
SHOPIFY_CATALOG_MODE=global
SHOPIFY_STORE_DOMAIN=
SHOPIFY_GLOBAL_ENDPOINT=https://catalog.shopify.com/api/ucp/mcp
SHOPIFY_AGENT_PROFILE_URL=
SHOPIFY_API_KEY=
SHOPIFY_QUERY_TIMEOUT_MS=8000
SHOPIFY_DEFAULT_PAGE_SIZE=20
SHOPIFY_CACHE_TTL_MS=30000
# Optional, Global Catalog only: layer in a ships_to filter (ISO-3166 alpha-2).
SHOPIFY_SHIPS_TO_COUNTRY=

# Shopify Provider App (merchant store → OCP Catalog).
# Reads products from a Shopify store via Admin GraphQL and pushes them to
# an OCP Catalog as a Provider. Default mock mode = no Shopify creds needed.
SHOPIFY_PROVIDER_ID=shopify_provider_local_dev
SHOPIFY_PROVIDER_DISPLAY_NAME=Shopify Merchant (local dev)
SHOPIFY_PROVIDER_CONTACT_EMAIL=ops@example.test
SHOPIFY_PROVIDER_PORT=4400
SHOPIFY_PROVIDER_PUBLIC_BASE_URL=http://localhost:4400
SHOPIFY_PROVIDER_ADMIN_KEY=dev-shopify-provider-admin-key
SHOPIFY_PROVIDER_MOCK=true
SHOPIFY_PROVIDER_STORE_DOMAIN=
SHOPIFY_PROVIDER_ACCESS_TOKEN=
SHOPIFY_PROVIDER_API_VERSION=2025-10
SHOPIFY_PROVIDER_DEFAULT_CURRENCY=USD
SHOPIFY_PROVIDER_PAGE_SIZE=50
SHOPIFY_PROVIDER_REQUEST_TIMEOUT_MS=15000
SHOPIFY_PROVIDER_WEBHOOK_SECRET=
SHOPIFY_PROVIDER_CATALOG_BASE_URL=http://localhost:4000
SHOPIFY_PROVIDER_CATALOG_ID=cat_local_dev
SHOPIFY_PROVIDER_CATALOG_API_KEY=dev-api-key
SHOPIFY_PROVIDER_STATE_FILE=

# WooCommerce Provider App (merchant store → OCP Catalog).
# Reads products from a WooCommerce site via WC REST API. Default mock mode.
WC_PROVIDER_ID=wc_provider_local_dev
WC_PROVIDER_DISPLAY_NAME=WooCommerce Merchant (local dev)
WC_PROVIDER_CONTACT_EMAIL=ops@example.test
WC_PROVIDER_PORT=4410
WC_PROVIDER_PUBLIC_BASE_URL=http://localhost:4410
WC_PROVIDER_ADMIN_KEY=dev-wc-provider-admin-key
WC_PROVIDER_MOCK=true
WC_PROVIDER_SITE_URL=
WC_PROVIDER_CONSUMER_KEY=
WC_PROVIDER_CONSUMER_SECRET=
# basic = Authorization header. query_string = ?consumer_key=&consumer_secret=
# (use the latter if your host strips Authorization headers).
WC_PROVIDER_AUTH_MODE=basic
WC_PROVIDER_API_VERSION=wc/v3
WC_PROVIDER_DEFAULT_CURRENCY=USD
WC_PROVIDER_PAGE_SIZE=50
WC_PROVIDER_REQUEST_TIMEOUT_MS=15000
WC_PROVIDER_WEBHOOK_SECRET=
WC_PROVIDER_CATALOG_BASE_URL=http://localhost:4000
WC_PROVIDER_CATALOG_ID=cat_local_dev
WC_PROVIDER_CATALOG_API_KEY=dev-api-key
WC_PROVIDER_STATE_FILE=
