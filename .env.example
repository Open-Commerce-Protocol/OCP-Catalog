# OCP Catalog v2 environment
#
# Copy this file to .env for local development. Keep real secrets out of
# committed files.

# PostgreSQL connection used by Drizzle.
DATABASE_URL=postgres://ocp:ocp@localhost:5432/ocp_catalog

# Main Catalog HTTP API.
CATALOG_API_PORT=4000

# Public base URL used in well-known discovery and CatalogManifest endpoints.
CATALOG_PUBLIC_BASE_URL=http://localhost:4000

# Commerce Provider HTTP API and public base URL.
PROVIDER_API_PORT=4200
PROVIDER_PUBLIC_BASE_URL=http://localhost:4200

# Commerce Provider admin web.
PROVIDER_ADMIN_UI_PORT=4210
VITE_PROVIDER_API_BASE_URL=http://localhost:4200

# User demo web.
USER_DEMO_UI_PORT=4220
USER_DEMO_API_PORT=4230
VITE_USER_DEMO_AGENT_API_BASE_URL=http://localhost:4230
VITE_REGISTRATION_DISCOVERY_URL=https://ocp.deeplumen.io/.well-known/ocp-registration
VITE_DEFAULT_CATALOG_QUERY_URL=http://localhost:4000/ocp/query
VITE_DEFAULT_CATALOG_RESOLVE_URL=http://localhost:4000/ocp/resolve
PROTOCOL_DOCS_PORT=5173

# OCP Catalog Registration node HTTP API.
REGISTRATION_API_PORT=4100

# Public base URL used in Registration node discovery and manifest endpoints.
REGISTRATION_PUBLIC_BASE_URL=https://ocp.deeplumen.io
REGISTRATION_DISCOVERY_URL=https://ocp.deeplumen.io/.well-known/ocp-registration

# Periodic refresh of verified/indexed Catalog manifests and health status.
REGISTRATION_REFRESH_SCHEDULER_ENABLED=true
REGISTRATION_REFRESH_INTERVAL_SECONDS=300

# Catalog identity for local development.
CATALOG_ID=cat_local_dev
CATALOG_NAME=Local OCP Catalog

# Commerce Provider identity for local development.
COMMERCE_PROVIDER_ID=commerce_provider_local_dev
COMMERCE_PROVIDER_NAME=Local Commerce Provider
COMMERCE_PROVIDER_CONTACT_EMAIL=ops@example.test
COMMERCE_PROVIDER_DOMAIN=localhost

# Registration node identity for local development.
REGISTRATION_ID=registration_local_dev
REGISTRATION_NAME=Local OCP Catalog Registration Node

# Development admin key accepted by x-api-key or Authorization: Bearer.
API_KEY_DEV=dev-api-key

# Optional comma-separated extra admin keys for local/shared environments.
API_KEYS=

# Semantic search embeddings are always enabled.
# If OPENAI_API_KEY is set, the catalog calls OPENAI_BASE_URL /embeddings.
# Without OPENAI_API_KEY, it falls back to deterministic local hash embeddings.
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
USER_DEMO_AGENT_MODEL=qwen3.6-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

