{
  "name": "ocp-catalog-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "apps/examples/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:demo": "turbo run dev --filter=@ocp-catalog/ocp-registration-api --filter=@ocp-catalog/commerce-catalog-api --filter=@ocp-catalog/commerce-provider-api --filter=@ocp-catalog/ocp-user-demo-api --filter=@ocp-catalog/site-web",
    "start:demo": "turbo run start --filter=@ocp-catalog/ocp-registration-api --filter=@ocp-catalog/commerce-catalog-api --filter=@ocp-catalog/commerce-provider-api --filter=@ocp-catalog/ocp-user-demo-api --filter=@ocp-catalog/site-web",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "bun run --cwd apps/commerce-catalog-api test:integration",
    "lint": "turbo lint",
    "site:check": "bun scripts/check-docs-integrity.ts",
    "commerce:catalog:api": "bun run --cwd apps/commerce-catalog-api start",
    "commerce:catalog:worker": "bun run --cwd apps/commerce-catalog-api worker",
    "commerce:catalog:admin": "bun run --cwd apps/examples/commerce-catalog-admin-web start",
    "registration:api": "bun run --cwd apps/ocp-registration-api start",
    "registration:admin": "bun run --cwd apps/ocp-registration-admin-web start",
    "commerce:provider:api": "bun run --cwd apps/examples/commerce-provider-api start",
    "commerce:provider:admin": "bun run --cwd apps/examples/commerce-provider-admin-web dev",
    "alimama:catalog:api": "bun run --cwd apps/examples/alimama-catalog-api start",
    "shopify:catalog:api": "bun run --cwd apps/examples/shopify-catalog-api start",
    "shopify:catalog:dev": "bun run --cwd apps/examples/shopify-catalog-api dev",
    "shopify:provider:app": "bun run --cwd apps/examples/shopify-provider-app start",
    "shopify:provider:dev": "bun run --cwd apps/examples/shopify-provider-app dev",
    "shopify:app": "bun run --cwd apps/examples/shopify-app start",
    "shopify:app:dev": "bun run --cwd apps/examples/shopify-app dev",
    "wc:provider:app": "bun run --cwd apps/examples/woocommerce-provider-app start",
    "wc:provider:dev": "bun run --cwd apps/examples/woocommerce-provider-app dev",
    "jdunion:catalog:api": "bun run --cwd apps/examples/jdunion-catalog-api start",
    "pdd:catalog:api": "bun run --cwd apps/examples/pdd-catalog-api start",
    "skill:gateway": "bun run --cwd apps/examples/ocp-skill-gateway start",
    "skill:gateway:dev": "bun run --cwd apps/examples/ocp-skill-gateway dev",
    "user:demo:api": "bun run --cwd apps/examples/ocp-user-demo-api start",
    "user:demo": "bun run --cwd apps/examples/ocp-user-demo-web dev",
    "webmcp:demo": "bun run --cwd apps/examples/ocp-webmcp-mcp-demo-web dev",
    "site:dev": "bun run --cwd apps/ocp-site-web dev",
    "site:start": "bun run --cwd apps/ocp-site-web start",
    "site:build": "bun run --cwd apps/ocp-site-web build",
    "skill:ocp:export": "bun scripts/export-ocp-skill.ts",
    "activity:api": "bun run --cwd apps/ocp-activity-api start",
    "mcp:gateway": "bun run --cwd apps/ocp-mcp-server start",
    "validate:mvp": "bun scripts/validate-mvp.ts",
    "validate:registration": "bun scripts/validate-registration.ts",
    "validate:mcp": "bun scripts/validate-mcp-gateway.ts",
    "validate:shopify-mvp": "bun scripts/validate-shopify-mvp.ts",
    "validate:shopify-e2e": "bun scripts/validate-shopify-end-to-end.ts",
    "validate:shopify-provider-e2e": "bun scripts/validate-shopify-provider-e2e.ts",
    "validate:wc-provider-e2e": "bun scripts/validate-wc-provider-e2e.ts",
    "validate:shopify-app-e2e": "bun scripts/validate-shopify-app-e2e.ts",
    "smoke:jdunion": "bun scripts/jdunion-mock-smoke.ts",
    "smoke:pdd": "bun scripts/pdd-mock-smoke.ts",
    "smoke:skill-gateway": "bun scripts/skill-gateway-smoke.ts",
    "smoke:mcp-skill": "bun scripts/mcp-skill-smoke.ts",
    "db:generate": "bun run --cwd packages/db generate",
    "db:migrate": "bun run --cwd packages/db migrate",
    "db:reset": "bun run --cwd packages/db reset",
    "db:recreate": "bun run db:reset",
    "db:studio": "bun run --cwd packages/db studio"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/bun": "^1.3.1",
    "@types/js-yaml": "^4.0.9",
    "drizzle-kit": "^0.31.8",
    "js-yaml": "^4.1.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
